<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#1A1D24"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- 号码显示 -->
    <TextView
        android:id="@+id/simSelectNumber"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="138****8888"
        android:textColor="#E8DCC8"
        android:textSize="22sp"
        android:textStyle="bold" />

    <!-- 上次通话提示 -->
    <TextView
        android:id="@+id/simSelectLastHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:text="上次：卡1  昨天"
        android:textColor="#C9A84C"
        android:textSize="15sp"
        android:visibility="gone" />

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="16dp"
        android:background="#2A2D34" />

    <!-- 卡1 按钮 -->
    <LinearLayout
        android:id="@+id/simSelectBtn1"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#22252E"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SIM"
            android:textColor="#C9A84C"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="1"
            android:textColor="#C9A84C"
            android:textSize="24sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="使用卡1拨打 →"
            android:textColor="#A09070"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- 间距 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="10dp" />

    <!-- 卡2 按钮 -->
    <LinearLayout
        android:id="@+id/simSelectBtn2"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#22252E"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SIM"
            android:textColor="#2ECC71"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="2"
            android:textColor="#2ECC71"
            android:textSize="24sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="使用卡2拨打 →"
            android:textColor="#A09070"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- 取消按钮 -->
    <TextView
        android:id="@+id/simSelectCancel"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="14dp"
        android:background="#2A2D34"
        android:gravity="center"
        android:text="取消"
        android:textColor="#A09070"
        android:textSize="15sp" />

</LinearLayout>
