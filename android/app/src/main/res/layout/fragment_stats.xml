<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111318"
    android:orientation="vertical">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="#1A1D24"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📊 拨号统计"
            android:textColor="#F0C040"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- 概览卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1A1D24"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="今日拨号"
                    android:textColor="#A09070"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/statsTodayCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="0"
                    android:textColor="#F0C040"
                    android:textSize="48sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="次"
                    android:textColor="#A09070"
                    android:textSize="14sp" />

                <View
                    android:layout_width="60dp"
                    android:layout_height="1dp"
                    android:layout_marginTop="20dp"
                    android:background="#C9A84C" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="累计拨号"
                    android:textColor="#A09070"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/statsTotalCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="0"
                    android:textColor="#E8DCC8"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="次"
                    android:textColor="#A09070"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- 近7天趋势标题 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:text="📈 近 7 天趋势"
                android:textColor="#E8DCC8"
                android:textSize="16sp" />

            <!-- 近7天柱状图（用 LinearLayout 模拟） -->
            <LinearLayout
                android:id="@+id/statsChartContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1A1D24"
                android:gravity="bottom|center_horizontal"
                android:orientation="horizontal"
                android:padding="16dp"
                android:paddingBottom="0dp">

                <!-- 7个柱子会在这里动态添加 -->

            </LinearLayout>

            <!-- 日期标签 -->
            <LinearLayout
                android:id="@+id/statsDateLabels"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1A1D24"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingBottom="12dp">

                <!-- 7个日期标签会动态添加 -->

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:background="#22262F" />

            <!-- 详细列表 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="12dp"
                android:text="📅 每日明细"
                android:textColor="#E8DCC8"
                android:textSize="16sp" />

            <LinearLayout
                android:id="@+id/statsDetailList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 动态添加每日明细行 -->

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="40dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
