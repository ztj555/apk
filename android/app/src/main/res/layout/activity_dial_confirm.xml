<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#111318"
    android:padding="28dp"
    android:gravity="center">

    <!-- 图标 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📞"
        android:textSize="48sp" />

    <!-- 标题 -->
    <TextView
        android:id="@+id/confirmTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="来电拨号请求"
        android:textColor="#F0C040"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- 号码 -->
    <TextView
        android:id="@+id/confirmNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="138 0000 0000"
        android:textColor="#E8DCC8"
        android:textSize="32sp"
        android:textStyle="bold"
        android:letterSpacing="2dp" />

    <!-- SIM信息 -->
    <TextView
        android:id="@+id/confirmSim"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="电脑选择: SIM 1"
        android:textColor="#A09070"
        android:textSize="13sp" />

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        android:background="#22262F" />

    <!-- SIM 1 按钮 -->
    <Button
        android:id="@+id/btnDialSim1"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="10dp"
        android:background="#1A3A2A"
        android:text="📶  使用 SIM 1 拨号"
        android:textColor="#2ECC71"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- SIM 2 按钮 -->
    <Button
        android:id="@+id/btnDialSim2"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="10dp"
        android:background="#1A1D24"
        android:text="📶  使用 SIM 2 拨号"
        android:textColor="#E8DCC8"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- 取消按钮 -->
    <Button
        android:id="@+id/btnCancel"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#2A1A1A"
        android:text="取消"
        android:textColor="#E74C3C"
        android:textSize="14sp" />

</LinearLayout>
